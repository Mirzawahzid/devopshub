# RapidAPI key for AI Nutritional Facts
RAPIDAPI_KEY=your_rapidapi_key_here

# OMDb API key for movie search and ratings
OMDB_API_KEY=your_omdb_api_key_here

# Express session signing secret (use a long random string, min 32 chars)
# Generate with: openssl rand -hex 32
SESSION_SECRET=your_session_secret_min_32_chars_here

# Port the Express server listens on (default: 3000)
PORT=3000

# Node.js environment
NODE_ENV=development
